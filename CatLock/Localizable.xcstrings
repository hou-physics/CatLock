    "overlay_sleep_warning": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "System will not sleep. Ensure sufficient battery."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统将不会进入睡眠。请确保电量充足。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "系統將不會進入睡眠。請確保電量充足。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "System wird nicht in den Ruhezustand wechseln. Stellen Sie ausreichend Akku sicher."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le système ne se mettra pas en veille. Assurez-vous d'avoir suffisamment de batterie."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il sistema non andrà in stop. Assicurati di avere batteria sufficiente."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El sistema no entrará en reposo. Asegúrate de tener suficiente batería."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システムはスリープしません。バッテリー残量を確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템이 잠자기 모드에 들어가지 않습니다. 배터리가 충분한지 확인하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Systeem gaat niet in sluimerstand. Zorg voor voldoende batterij."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O sistema não entrará em repouso. Certifique-se de ter bateria suficiente."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem uyku moduna geçmeyecek. Yeterli pil olduğundan emin olun."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ระบบจะไม่เข้าสู่โหมดพักเครื่อง โปรดตรวจสอบแบตเตอรี่ให้เพียงพอ"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لن يدخل النظام في وضع السكون. تأكد من شحن البطارية الكافي."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "سیستم به حالت خواب نمی‌رود. از شارژ کافی باتری اطمینان حاصل کنید."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "המערכת לא תיכנס למצב שינה. ודא שיש מספיק סוללה."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το σύστημα δεν θα τεθεί σε αναστολή. Βεβαιωθείτε ότι υπάρχει αρκετή μπαταρία."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "System nie przejdzie w tryb uśpienia. Upewnij się, że bateria jest wystarczająco naładowana."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Systém nepřejde do režimu spánku. Zajistěte dostatečnou baterii."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Systemet kommer inte att försättas i viloläge. Se till att batteriet räcker."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Järjestelmä ei mene lepotilaan. Varmista riittävä akun varaus."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Systemet vil ikke gå i dvale. Sørg for tilstrekkelig batteri."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Система не перейдёт в режим сна. Убедитесь в достаточном заряде батареи."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Система не перейде в режим сну. Переконайтеся, що заряд батареї достатній."
          }
        }
      }
    },
