    "about_quote": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I pass my mornings on the warm rice vessel, evenings on the kotatsu, and warm days sunning on the veranda."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "早晨睡在饭桶盖上，夜里睡在暖炉上，晴朗的中午睡在檐廊中。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
