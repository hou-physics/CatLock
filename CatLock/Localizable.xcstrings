          "stringUnit": {
            "state": "translated",
            "value": "Το CatLock χρειάζεται άδεια προσβασιμότητας"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "CatLock wymaga uprawnienia dostępności"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "CatLock vyžaduje oprávnění přístupnosti"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "CatLock behöver behörighet för hjälpmedel"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "CatLock tarvitsee esteettömyysoikeuden"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "CatLock trenger tilgjengelighetstillatelse"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "CatLock требуется разрешение универсального доступа"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "CatLock потребує дозволу на доступність"
          }
        }
      }
    },
    "permission_alert_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To intercept keyboard and mouse input, CatLock needs accessibility permission. Please grant it in System Settings."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为了拦截键盘和鼠标输入，CatLock 需要辅助功能权限。请在系统设置中授予权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "為了攔截鍵盤和滑鼠輸入，CatLock 需要輔助使用權限。請在系統設定中授予權限。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Um Tastatur- und Mauseingaben abzufangen, benötigt CatLock die Bedienungshilfen-Berechtigung. Bitte erteilen Sie diese in den Systemeinstellungen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour intercepter les entrées clavier et souris, CatLock a besoin de l'autorisation d'accessibilité. Veuillez l'accorder dans les Réglages Système."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per intercettare l'input di tastiera e mouse, CatLock necessita dell'autorizzazione accessibilità. Concedila in Impostazioni di Sistema."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Para interceptar la entrada del teclado y ratón, CatLock necesita permiso de accesibilidad. Por favor, concédelo en Ajustes del Sistema."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キーボードとマウスの入力を傍受するために、CatLock にはアクセシビリティの許可が必要です。システム設定で許可してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "키보드 및 마우스 입력을 가로채려면 CatLock에 손쉬운 사용 권한이 필요합니다. 시스템 설정에서 권한을 부여해 주세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Om toetsenbord- en muisinvoer te onderscheppen heeft CatLock toegankelijkheidsmachtiging nodig. Verleen deze in Systeeminstellingen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Para interceptar a entrada do teclado e mouse, o CatLock precisa de permissão de acessibilidade. Conceda-a nos Ajustes do Sistema."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Klavye ve fare girişini engellemek için CatLock'un erişilebilirlik iznine ihtiyacı var. Lütfen Sistem Ayarları'ndan izin verin."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เพื่อดักจับการป้อนข้อมูลจากแป้นพิมพ์และเมาส์ CatLock ต้องการสิทธิ์การช่วยการเข้าถึง โปรดอนุญาตในการตั้งค่าระบบ"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لاعتراض إدخال لوحة المفاتيح والماوس، يحتاج CatLock إلى إذن إمكانية الوصول. يرجى منحه في إعدادات النظام."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "برای رهگیری ورودی صفحه‌کلید و ماوس، CatLock به مجوز دسترس‌پذیری نیاز دارد. لطفاً آن را در تنظیمات سیستم اعطا کنید."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "כדי ליירט קלט מקלדת ועכבר, CatLock זקוק להרשאת נגישות. אנא הענק אותה בהגדרות המערכת."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Για να υποκλέψει είσοδο πληκτρολογίου και ποντικιού, το CatLock χρειάζεται άδεια προσβασιμότητας. Χορηγήστε τη στις Ρυθμίσεις Συστήματος."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aby przechwytywać dane z klawiatury i myszy, CatLock potrzebuje uprawnienia dostępności. Przyznaj je w Ustawieniach systemu."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro zachycení vstupu z klávesnice a myši potřebuje CatLock oprávnění přístupnosti. Udělte ho v Nastavení systému."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "För att fånga tangentbords- och musinmatning behöver CatLock behörighet för hjälpmedel. Bevilja den i Systeminställningar."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Näppäimistö- ja hiirisyötteen sieppaamiseen CatLock tarvitsee esteettömyysoikeuden. Myönnä se Järjestelmäasetuksissa."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "For å fange opp tastatur- og museinndata trenger CatLock tilgjengelighetstillatelse. Gi tillatelsen i Systeminnstillinger."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для перехвата ввода с клавиатуры и мыши CatLock требуется разрешение универсального доступа. Предоставьте его в Системных настройках."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Для перехоплення введення з клавіатури та миші CatLock потребує дозволу на доступність. Надайте його в Системних налаштуваннях."
          }
        }
      }
    },
